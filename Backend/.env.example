# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGO_URL=mongodb+srv://your_db_user:your_password@cluster0.example.mongodb.net/?appName=Cluster0

# JWT Configuration
ACCESS_TOKEN_SECRET=your_access_token_secret_123456789
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_SECRET=your_refresh_token_secret_987654321
MONGO_URL=mongodb://localhost:27017/collab-canvas

# JWT Configuration (used for account activation tokens)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Access & Refresh Token Configuration (used for auth)
ACCESS_TOKEN_SECRET=your-access-token-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_SECRET=your-refresh-token-secret
REFRESH_TOKEN_TTL=7d

# CORS Configuration
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,https://your-azure-static-app-url.azurestaticapps.net

# Email Configuration (for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com

# Cloudinary Configuration (Cloud Media Storage - images, thumbnails, canvas data)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# AI Agent
GROQ_API_KEY=your_groq_api_key