# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGO_URL=mongodb://localhost:27017/collab-canvas

# JWT Configuration (used for account activation tokens)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Access & Refresh Token Configuration (used for auth)
ACCESS_TOKEN_SECRET=your-access-token-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_SECRET=your-refresh-token-secret
REFRESH_TOKEN_TTL=7d

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Email Configuration (for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@collabcanvas.com

# Cloudinary Configuration (Cloud Media Storage - images, thumbnails, canvas data)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# for AI Agent
GROQ_API_KEY=your-groq-api-key